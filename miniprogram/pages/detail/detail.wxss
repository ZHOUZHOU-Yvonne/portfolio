.page {
  padding-bottom: 40rpx;
}

.header-img {
  width: 100%;
  height: 360rpx;
}

.card {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.service-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}
.service-price {
  font-size: 36rpx;
  color: #e74c3c;
  font-weight: 700;
  display: block;
  margin: 12rpx 0;
}
.service-desc {
  font-size: 28rpx;
  color: #888;
  line-height: 1.8;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin: 20rpx 30rpx 10rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #4A90D9;
}

.picker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
}
.picker-val {
  color: #888;
}

.form-input {
  border-bottom: 1rpx solid #eee;
  padding: 20rpx 0;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}
.form-textarea {
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  margin-top: 20rpx;
  min-height: 120rpx;
}

.btn-submit {
  margin: 30rpx 20rpx;
  background: #4A90D9;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx;
  text-align: center;
}
.btn-submit:active {
  opacity: 0.8;
}

.footer {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
}
