.page {
  padding-bottom: 40rpx;
}

.banner {
  position: relative;
  height: 400rpx;
}
.banner-img {
  width: 100%;
  height: 100%;
}
.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 30rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
  color: #fff;
}
.banner-title {
  font-size: 42rpx;
  font-weight: 700;
  display: block;
}
.banner-desc {
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 8rpx;
}

.quick-actions {
  display: flex;
  background: #fff;
  padding: 30rpx 0;
  margin: -20rpx 20rpx 0;
  border-radius: 16rpx;
  position: relative;
  z-index: 10;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}
.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}
.action-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 8rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  margin: 40rpx 30rpx 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #4A90D9;
}

.service-card {
  display: flex;
  padding: 20rpx;
  margin: 0 20rpx 20rpx;
}
.service-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.service-info {
  flex: 1;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
}
.service-name {
  font-size: 30rpx;
  font-weight: 600;
}
.service-desc {
  font-size: 24rpx;
  color: #888;
  margin: 8rpx 0;
  flex: 1;
}
.service-price {
  font-size: 30rpx;
  color: #e74c3c;
  font-weight: 600;
}
.btn-book {
  background: #4A90D9;
  color: #fff;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.about-card {
  margin: 0 20rpx;
}
.about-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #555;
}
.contact-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
  font-size: 28rpx;
  color: #4A90D9;
}

.footer {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #bbb;
}
